# Copy to .env and fill in. `docker compose` reads this automatically.

# Domain that points (A record) at the droplet. Serves BOTH the app (https)
# and the TURN server (turns://<domain>:5349). Must resolve before you deploy.
DOMAIN=ahey.net

# Public IPv4 of the droplet (used by coturn's external-ip for NAT hints).
EXTERNAL_IP=127.0.0.1

# Email for Let's Encrypt registration / expiry notices.
LETSENCRYPT_EMAIL=you@example.com

# Shared secret between the app and coturn. Generate with:
#   openssl rand -hex 32
TURN_SECRET=replace-with-a-long-random-secret

# How long minted TURN credentials stay valid (seconds). 86400 = 24h.
TURN_TTL=86400
